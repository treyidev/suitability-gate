# SuitabilityGate — local environment. Copy to .env and adjust; .env is gitignored (never commit secrets).
# These are DEV defaults.
#
# Datastore: the Decision Record store defaults to file-backed H2 — in-process, no container, and it
# persists across restarts to core/data/*.mv.db. That default lives in core/src/main/resources/
# application.properties, so nothing needs setting here to run on H2. To run against Postgres instead,
# use the opt-in block at the bottom of this file.

# JWT signing secret (>= 32 bytes for HS256). Change for anything beyond local dev.
JWT_SECRET=dev-only-suitabilitygate-hmac-signing-secret-change-me-0123456789
JWT_TTL_MINUTES=60

# Explanation service (the one Java→Python call; async, never in the verdict path)
EXPLANATION_URL=http://localhost:8000
EXPLANATION_PORT=8000
EXPLANATION_DELAY_MS=500

# Frontend origin allowed by the gateway's CORS policy (Vite dev server)
FRONTEND_ORIGIN=http://localhost:5173

# Demo logins (hardcoded identities, D9):
#   rm.demo / password  ·  supervisor.demo / password  ·  customer.demo / password

# ── OPT-IN: Postgres store ───────────────────────────────────────────────────────────────────
# Default is H2 — leave this whole block commented to stay on H2. To switch to Postgres:
#   1) start the container:   COMPOSE_PROFILES=postgres docker compose up -d
#   2) uncomment ALL lines below (the DB_* lines override the H2 default), then (re)start the core.
# The container's POSTGRES_* and the core's DB_* must agree.
# POSTGRES_DB=suitabilitygate
# POSTGRES_USER=suitability
# POSTGRES_PASSWORD=suitability
# POSTGRES_PORT=5432
# DB_URL=jdbc:postgresql://localhost:5432/suitabilitygate
# DB_USER=suitability
# DB_PASSWORD=suitability
# DB_DRIVER=org.postgresql.Driver
